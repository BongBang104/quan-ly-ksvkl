# ── Database ──────────────────────────────────────────────────────────────────
# Dùng cho PostgreSQL container và cả backend + analytics
DB_USER=postgres
DB_PASSWORD=
DB_NAME=atc_pro

# ── JWT ───────────────────────────────────────────────────────────────────────
# Sinh bằng: openssl rand -base64 48
# Độ dài tối thiểu: 32 ký tự
JWT_SECRET=

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL trình duyệt dùng để truy cập frontend (không có trailing slash)
# Dev local:    http://localhost:5173
# Production:   https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ── Superadmin ────────────────────────────────────────────────────────────────
# ID tài khoản superadmin ẩn (đổi thành ID khó đoán trước khi deploy)
HIDDEN_ADMIN_ID=tctsvip

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Sinh keys: npx web-push generate-vapid-keys (chạy trong thư mục backend/)
# Điền vào backend/.env, không cần ở file này (public key được serve qua API)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@atcpro.local
