# ── PostgreSQL ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=atc_pro

# ── JWT ───────────────────────────────────────────────────────────────────
# JWT_SECRET phải có độ dài >= 32 ký tự. Sinh bằng: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── App ───────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Analytics (FastAPI) ───────────────────────────────────────────────────
# URL của analytics service — phải trùng với port trong analytics/dev.bat
ANALYTICS_URL=http://localhost:8001

# ── Superadmin ────────────────────────────────────────────────────────────────
# ID tài khoản superadmin ẩn. Đổi thành ID khó đoán trước khi deploy production.
# Mật khẩu được sinh ngẫu nhiên lần đầu khởi động và in ra console 1 lần duy nhất.
HIDDEN_ADMIN_ID=tctsvip

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Sinh keys một lần duy nhất: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY dùng ở cả backend lẫn frontend (trả về qua GET /api/push/vapid-public-key)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Đổi thành email thật — browser vendor (Google/Mozilla) dùng để liên lạc nếu có vấn đề
VAPID_EMAIL=mailto:admin@yourdomain.com
